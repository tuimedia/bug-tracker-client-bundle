{
    "name": "tuimedia/bug-tracker-client-bundle",
    "description": "Symfony bundle for consumer projects to submit bug reports to the Tui bug tracker",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/http-client": "^6.4|^7.0",
        "symfony/security-bundle": "^6.4|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "symfony/phpunit-bridge": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Tui\\BugTrackerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tui\\BugTrackerBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": false
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    }
}
